      <column caption='Total Orders' datatype='integer' name='[Calculation_1819735768536227840]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([no_pesanan])' />
      </column>
      <column caption='AOV' datatype='real' name='[Calculation_1819735768536764417]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([net_sales]) * 1000 / COUNTD([no_pesanan])' />
      </column>
      <column caption='Cancellation Rate' datatype='real' default-format='p0.00%' name='[Calculation_1819735768537075714]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [status_pesanan] = &quot;Batal&quot;&#13;&#10;THEN [no_pesanan]&#13;&#10;END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([no_pesanan])' />
      </column>
      <column caption='Net Sales (IDR)' datatype='real' name='[Calculation_1819735768767184900]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([net_sales]) / 1000' />
      </column>
